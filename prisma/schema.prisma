generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Breed {
  id           String   @id @default(cuid())
  apiId        String   @unique
  nameEn       String
  nameKo       String?
  origin       String?
  temperament  String?
  description  String?
  lifeSpan     String?
  wikipediaUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// 급여(사료) 카탈로그 — OPFF 시드 또는 prisma/cat_food.csv 수동 임포트
model FeedProduct {
  id           String   @id @default(cuid())
  apiId        String   @unique
  feedKind     String
  brand        String?
  name         String
  nameKo       String?
  displayLabel String
  sourceUrl    String?
  lifeStage    String?
  kcalPer100g  Float?
  /// 습식 1캔(1팩) 기준 무게(g). 건식은 null
  servingGrams Float?
  /// 건식 브랜드 급여 가이드 — 하루 권장 그램 (guide_weight_kg 체중 기준)
  servingGuideGrams Float?
  /// 브랜드 급여 가이드 기준 체중(kg). 비우면 4kg
  servingGuideWeightKg Float?
  /// cat_food.csv `category` (예: general)
  category      String?
  /// cat_food.csv `condition` (예: none, urinary, weight)
  feedCondition String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// SEO 파일럿(상위 20) 대상 사료 — GSC 조회수 기준 수동 지정
model SeoBoostPilotFeed {
  feedApiId String   @id
  sortOrder Int      @default(0)
  gscNote   String?
  createdAt DateTime @default(now())
}

/// OpenAI로 생성한 사료 상세 SEO 부스트 콘텐츠 (빌드 시 JSON 캐시로 동기화)
model FeedSeoBoostContent {
  feedApiId        String   @id
  recommendedFor   String
  feedingNotes     String
  comparisonPoints String
  openaiModel      String?
  promptVersion    String   @default("1")
  generatedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// 공유 결과 단축 링크 저장소
model SharedResult {
  id        String   @id @default(cuid())
  shortId   String   @unique
  payload   String
  createdAt DateTime @default(now())
}
