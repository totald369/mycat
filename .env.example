DATABASE_URL="file:./dev.db"
# 선택: The Cat API 키 (없어도 무료 호출 가능, 제한만 다를 수 있음)
# CAT_API_KEY=

# 선택: 급여(사료) 영문명 → 한글 Papago 번역 (네이버 개발자센터 애플리케이션 등록)
# 없으면 시드 시 OPFF에 있는 한글/다국어 필드만 자동 사용합니다.
# FEED_PAPAGO_CLIENT_ID=
# FEED_PAPAGO_CLIENT_SECRET=
# 한 시드 실행당 번역 호출 상한 (0이면 Papago 미사용)
# FEED_PAPAGO_MAX=300
